---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostMeta from '../components/PostMeta.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { postStats } from '../utils/post-stats';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} /></head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="eyebrow">个人博客</p>
				<h2>学习、构建</h2>
			</section>
			<section aria-labelledby="recent-posts">
				<div class="section-title"><h2 id="recent-posts">最新文章</h2><a href={`${base}blog/`}>全部文章 →</a></div>
				<ul class="post-list">
					{posts.map((post) => <li><a href={`${base}blog/${post.id}/`}><h3>{post.data.title}</h3><p>{post.data.description}</p><PostMeta {...post.data} {...postStats(post.body)} /></a></li>)}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
