---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION } from '../../consts';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const base = `${import.meta.env.BASE_URL}/`;
---

<!doctype html>
<html lang="zh-CN">
	<head><BaseHead title="文章 | losh" description={SITE_DESCRIPTION} /></head>
	<body><Header /><main><section><p class="eyebrow">ARCHIVE</p><h1>全部文章</h1><ul class="post-list">{posts.map((post) => <li><a href={`${base}blog/${post.id}/`}><time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</time><h2>{post.data.title}</h2><p>{post.data.description}</p></a></li>)}</ul></section></main><Footer /></body>
</html>
